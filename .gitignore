# =====================================================================
# MemoryBridge — root .gitignore
# =====================================================================

# ── Environment / Secrets ─────────────────────────────────────────────
.env
.env.*
!.env.example

**/.env
**/.env.*
!**/.env.example

# ── Python virtual environments ───────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Python cache and build artefacts ─────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/
.tox/
*.egg-info/
dist/
build/

# ── Local databases and SQLite files ─────────────────────────────────
*.db
*.sqlite
*.sqlite3
test.db

# ── Node / Next.js ────────────────────────────────────────────────────
node_modules/
.next/
out/

# ── Test artefacts ────────────────────────────────────────────────────
playwright-report/
test-results/
coverage/

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
