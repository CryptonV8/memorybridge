# =====================================================================
# MemoryBridge — .env.example
# Copy to .env (root) or the appropriate service directory and fill in.
# NEVER commit real credentials. This file contains placeholders only.
# =====================================================================

# ── Database ──────────────────────────────────────────────────────────
# Neon pooled connection string (used at runtime by the MCP server)
DATABASE_URL=

# Neon direct/unpooled connection string (used by Alembic migrations)
# Falls back to DATABASE_URL when not set.
MIGRATION_DATABASE_URL=

# ── Gemini / ADK ──────────────────────────────────────────────────────
# Your Google AI Studio or Vertex AI API key
GOOGLE_API_KEY=

# Gemini model identifier — not a secret, safe to set as a plain env var.
# Current recommended value for this SDK version: gemini-2.5-flash
# gemini-2.5-pro is the legacy default (supported until at least Oct 2026).
MEMORYBRIDGE_MODEL=gemini-2.5-flash

# Agent provider: "gemini" for live LLM, "fake" for deterministic local mode
AGENT_PROVIDER=fake

# ── Session / Authentication ──────────────────────────────────────────
# iron-session encryption secret — minimum 32 random characters
SESSION_SECRET=

# Demo bearer tokens recognised by the FastAPI gateway
# These must match the token lookup in services/agent-api/src/memorybridge_agent/dependencies.py
DEMO_CAREGIVER_TOKEN=
DEMO_ASSISTED_USER_TOKEN=

# ── Service Configuration ─────────────────────────────────────────────
# Base URL of the FastAPI Agent Service (server-side only — never exposed to the browser)
AGENT_API_BASE_URL=http://localhost:8000

# Comma-separated list of allowed CORS origins for the backend
# In production, set to the Cloud Run web service URL only.
ALLOWED_ORIGINS=http://localhost:3000

# Runtime environment label ("development" | "production")
ENVIRONMENT=development

# Log verbosity
LOG_LEVEL=INFO

# ── Tests ─────────────────────────────────────────────────────────────
# Separate PostgreSQL DB for the integration/E2E test suite
TEST_DATABASE_URL=

# ── Observability (optional) ─────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=memorybridge
