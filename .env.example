# ==========================================
# MemoryBridge: Root Environment Config Example
# ==========================================

# ------------------------------------------
# 1. Next.js UI Environment (apps/web/.env.local)
# ------------------------------------------
# The base URL of the FastAPI gateway API service
AGENT_API_BASE_URL=http://127.0.0.1:8000

# The caregiver credential token (never exposed to browser)
DEMO_CAREGIVER_TOKEN=demo-token-123

# Encrypted session secret key (must be at least 32 characters long)
DEMO_SESSION_SECRET=super_secret_session_key_that_is_at_least_32_chars


# ------------------------------------------
# 2. Agent API Service Gateway Environment (services/agent-api/.env)
# ------------------------------------------
# Provider mode: "fake" (for deterministic local tests) or "gemini" (for live LLM)
AGENT_PROVIDER=fake

# Google Gemini API key (only required if AGENT_PROVIDER=gemini)
GOOGLE_API_KEY=

# Target Gemini model to use for routine interpretation
MEMORYBRIDGE_MODEL=gemini-2.5-pro

# Logging severity level
LOG_LEVEL=INFO


# ------------------------------------------
# 3. MCP Routines Server Environment (services/mcp-routines/.env)
# ------------------------------------------
# Database connection URL for Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Connection URL used specifically during pytest execution
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/test_dbname

# ------------------------------------------
# 4. Tracing and Observability (Optional)
# ------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=memorybridge
